{% extends 'base.html.twig' %}

{% block title %}{{ title|default('Products') }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2 fw-bold">
        <i class="bi bi-grid-fill text-warning me-2"></i>{{ title|default('Products') }}
    </h1>
    {# Show "New Product" button only on My Products page #}
    {% if show_new_button|default(false) %}
        <a href="{{ path('app_product_new') }}" class="btn btn-warning">
            <i class="bi bi-plus-circle-fill me-1"></i>New Product
        </a>
    {% endif %}
</div>

{% if products is empty %}
    {# Empty state message #}
    <div class="text-center py-5">
        <i class="bi bi-inbox display-1 text-muted"></i>
        <p class="mt-3 text-muted fs-5">{{ empty_message|default('No products found.') }}</p>
        {% if app.user %}
            <a href="{{ path('app_product_new') }}" class="btn btn-warning mt-2">
                <i class="bi bi-plus-circle-fill me-1"></i>Publish your first product
            </a>
        {% endif %}
    </div>
{% else %}
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
        {% for product in products %}
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    {# Product image #}
                    <img
                        src="{{ product.image ?? 'https://picsum.photos/seed/' ~ product.id ~ '/640/480' }}"
                        class="card-img-top"
                        alt="{{ product.title }}"
                        onerror="this.src='https://picsum.photos/640/480?grayscale'"
                    >
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold">{{ product.title }}</h5>
                        {# Truncate description to 100 characters #}
                        <p class="card-text text-muted flex-grow-1">
                            {{ product.description|length > 100 ? product.description|slice(0, 100) ~ '...' : product.description }}
                        </p>
                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <span class="badge bg-success price-badge">{{ product.price|number_format(2, '.', ',') }} €</span>
                            <small class="text-muted">
                                <i class="bi bi-person me-1"></i>{{ product.owner.name }}
                            </small>
                        </div>
                        <small class="text-muted mt-1">
                            <i class="bi bi-calendar3 me-1"></i>{{ product.createdAt|date('d/m/Y') }}
                        </small>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3">
                        <a href="{{ path('app_product_show', {id: product.id}) }}" class="btn btn-outline-dark btn-sm w-100">
                            <i class="bi bi-eye me-1"></i>View Details
                        </a>
                        {# Show edit/delete buttons only on My Products page (show_actions = true) #}
                        {% if show_actions|default(false) %}
                            <div class="d-flex gap-2 mt-2">
                                <a href="{{ path('app_product_edit', {id: product.id}) }}" class="btn btn-outline-primary btn-sm flex-fill">
                                    <i class="bi bi-pencil me-1"></i>Edit
                                </a>
                                <form method="post" action="{{ path('app_product_delete', {id: product.id}) }}" class="flex-fill"
                                      onsubmit="return confirm('Are you sure you want to delete this product?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                                    <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                                        <i class="bi bi-trash me-1"></i>Delete
                                    </button>
                                </form>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}