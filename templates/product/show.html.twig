{% extends 'base.html.twig' %}

{% block title %}{{ product.title }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-8">

        {# Back button #}
        <a href="{{ path('app_product_index') }}" class="btn btn-outline-secondary mb-3">
            <i class="bi bi-arrow-left me-1"></i>Back to Products
        </a>

        <div class="card shadow border-0">
            {# Product image #}
            <img
                src="{{ product.image ?? 'https://picsum.photos/seed/' ~ product.id ~ '/640/480' }}"
                class="card-img-top"
                style="max-height: 400px; object-fit: cover;"
                alt="{{ product.title }}"
                onerror="this.src='https://picsum.photos/640/480?grayscale'"
            >
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                    <h1 class="h2 fw-bold">{{ product.title }}</h1>
                    <span class="badge bg-success fs-5 price-badge">{{ product.price|number_format(2, '.', ',') }} €</span>
                </div>

                <hr>

                <p class="lead">{{ product.description }}</p>

                <hr>

                {# Owner info #}
                <div class="d-flex justify-content-between align-items-center text-muted">
                    <span><i class="bi bi-person-circle me-1"></i>Published by <strong>{{ product.owner.name }}</strong></span>
                    <span><i class="bi bi-calendar3 me-1"></i>{{ product.createdAt|date('d/m/Y H:i') }}</span>
                </div>

                {# Show edit/delete only if the authenticated user is the owner #}
                {% if app.user and app.user == product.owner %}
                    <div class="d-flex gap-2 mt-4">
                        <a href="{{ path('app_product_edit', {id: product.id}) }}" class="btn btn-primary">
                            <i class="bi bi-pencil-fill me-1"></i>Edit Product
                        </a>
                        <form method="post" action="{{ path('app_product_delete', {id: product.id}) }}"
                              onsubmit="return confirm('Are you sure you want to delete this product? This action cannot be undone.')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash-fill me-1"></i>Delete Product
                            </button>
                        </form>
                    </div>
                {% endif %}
            </div>
        </div>

    </div>
</div>
{% endblock %}